      "slide_number": 3,
      "section": "background",
      "title": "Background & Motivation",
      "key_message": "Adaptive methods converge faster but may generalize worse than SGD.",
      "layout_type": "title_content",
      "background_color": null,
      "footer_override": null,
      "text_elements": [
        {
          "element_id": "s003_title",
          "role": "title",
          "content": "Background & Motivation",
          "position": {"x": 2.0, "y": 0.5, "w": 29.87, "h": 2.0},
          "style": {"font_size": 28, "bold": true, "italic": false, "underline": false, "color": "#1F3864", "align": "left"},
          "z_index": 0
        },
        {
          "element_id": "s003_body",
          "role": "body",
          "content": "• Static learning rates cause slow convergence or instability\n• Adam combines momentum with per-parameter adaptive rates\n• AdaGrad adapts using cumulative gradient history\n• RMSProp uses exponentially weighted moving average\n• Prior work: adaptive methods may generalize worse than SGD",
          "position": {"x": 2.0, "y": 3.2, "w": 29.87, "h": 14.35},
          "style": {"font_size": 20, "bold": false, "italic": false, "underline": false, "color": "#000000", "align": "left"},
          "z_index": 0
        }
      ],
      "chart_elements": [],
      "image_elements": [],
      "table_elements": [],
      "speaker_note": "Emphasise the generalization gap problem as the key motivation.",
